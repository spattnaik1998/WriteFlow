# OpenAI API
OPENAI_API_KEY=sk-...

# Serper API (Google Search)
SERPER_API_KEY=...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
# service_role secret key — Project Settings → API → service_role. Server-side
# only, bypasses Row Level Security. NEVER commit this or expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Only this email is allowed to sign in (GitHub OAuth via Supabase Auth) and
# use the app — there is no per-user data model, every table is shared.
ALLOWED_EMAIL=you@example.com

# Server
PORT=3000
